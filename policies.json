{
  "policies": {
    "DisableTelemetry": true,
    "DisableFirefoxStudies": true,
    "DisableFirefoxAccounts": true,
    "DisablePocket": true,
    "DontCheckDefaultBrowser": true,
    "DisableFormHistory": true,
    "PasswordManagerEnabled": false,
    "OfferToSaveLogins": false,
    "SanitizeOnShutdown": {
      "Cache": true,
      "Cookies": true,
      "Downloads": true,
      "FormData": true,
      "History": true,
      "Sessions": true,
      "OfflineApps": true,
      "Locked": true
    },
    "Cookies": {
      "Behavior": "reject-tracker",
      "ExpireAtSessionEnd": true,
      "Locked": true
    },
    "DNSOverHTTPS": {
      "Enabled": true,
      "ProviderURL": "https://mozilla.cloudflare-dns.com/dns-query",
      "Locked": true
    },
    "NetworkPrediction": false,
    "NoDefaultBookmarks": true,
    "DisplayMenuBar": "default-off",
    "HardwareAcceleration": false,
    "OverrideFirstRunPage": "",
    "OverridePostUpdatePage": "",
    "DisableAppUpdate": true,
    "BlockAboutAddons": false,
    "FirefoxHome": {
      "Search": false,
      "TopSites": false,
      "SponsoredTopSites": false,
      "Highlights": false,
      "Pocket": false,
      "SponsoredPocket": false,
      "Snippets": false,
      "Locked": true
    },
    "UserMessaging": {
      "WhatsNew": false,
      "ExtensionRecommendations": false,
      "FeatureRecommendations": false,
      "UrlbarInterventions": false,
      "SkipOnboarding": true,
      "Locked": true
    },
    "SearchEngines": {
      "PreventInstalls": true
    },
    "Preferences": {
      "media.peerconnection.enabled":         { "Value": false, "Status": "locked" },
      "media.navigator.enabled":              { "Value": false, "Status": "locked" },
      "media.peerconnection.ice.no_host":     { "Value": true,  "Status": "locked" },
      "media.peerconnection.ice.proxy_only":  { "Value": true,  "Status": "locked" },
      "geo.enabled":                          { "Value": false, "Status": "locked" },
      "dom.battery.enabled":                  { "Value": false, "Status": "locked" },
      "privacy.resistFingerprinting":         { "Value": true,  "Status": "locked" },
      "security.tls.version.min":             { "Value": 3,     "Status": "locked" },
      "network.proxy.type":                   { "Value": 1,     "Status": "locked" },
      "network.proxy.socks":                  { "Value": "127.0.0.1", "Status": "locked" },
      "network.proxy.socks_port":             { "Value": 1080,  "Status": "locked" },
      "network.proxy.socks_version":          { "Value": 5,     "Status": "locked" },
      "network.proxy.socks_remote_dns":       { "Value": true,  "Status": "locked" },
      "network.proxy.failover_direct":        { "Value": false, "Status": "locked" },
      "network.dns.disableIPv6":              { "Value": true,  "Status": "locked" }
    }
  }
}
